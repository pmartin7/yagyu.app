# Database
NEON_DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Firebase Admin SDK (server)
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com

# Firebase client SDK (web, build-time)
VITE_FIREBASE_API_KEY=AIzaSy...
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abc123

# AI Providers (at least one required)
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# Which model to use — format: provider:model-id
# Examples: anthropic:claude-sonnet-5  openai:gpt-4o
DEFAULT_AI_MODEL=anthropic:claude-sonnet-5

# Observability (optional)
AXIOM_TOKEN=xaat-...
AXIOM_DATASET=forge-logs

# App
NODE_ENV=development
PORT=3000
CORS_ORIGIN=http://localhost:5173

# Vercel Blob (optional — add-blob-storage skill)
# BLOB_READ_WRITE_TOKEN=vercel_blob_rw_...
